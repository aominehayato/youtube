{
  "name": "siatube-backend",
  "version": "2.1.0",
  "description": "SiaTube Production Backend API Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "preinstall": "mkdir -p bin",
    "postinstall": "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_linux -o bin/yt-dlp && chmod +x bin/yt-dlp",
    "start": "node server.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "express": "^4.19.2",
    "youtubei.js": "^14.0.0"
  }
}
