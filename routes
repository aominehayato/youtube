import express from "express";
import { Innertube } from "youtubei.js";

const router = express.Router();
let youtubeInstance = null;

/**
 * youtubei.js インスタンスの初期化（非同期）
 */
async function getYouTubeInstance() {
  if (!youtubeInstance) {
    youtubeInstance = await Innertube.create({
      lang: "ja",
      location: "JP"
    });
  }
  return youtubeInstance;
}

/**
 * GET /api/video/:id
 * 指定された動画IDの詳細情報を取得してJSONで返却する
 */
router.get("/:id", async (req, res) => {
  const videoId = req.params.id;

  try {
    const youtube = await getYouTubeInstance();
    const info = await youtube.getInfo(videoId);

    res.json({
      id: videoId,
      title: info.basic_info.title,
      views: info.basic_info.view_count,
      author: info.basic_info.author,
      thumbnail: info.basic_info.thumbnail && info.basic_info.thumbnail.length > 0 ? info.basic_info.thumbnail[0].url : ""
    });

  } catch (error) {
    console.error("Error fetching video info for ID " + videoId + ":", error);
    res.status(500).json({
      error: error.message
    });
  }
});

export default router;
